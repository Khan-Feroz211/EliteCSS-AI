# Copy to .env.docker and fill in real values
# This file is used by docker-compose — never commit .env.docker to git

# LLM API Keys
OPENAI_API_KEY=sk-proj-your-openai-key-here
CLAUDE_API_KEY=sk-ant-your-anthropic-key-here
GEMINI_API_KEY=your-gemini-key-here

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=choose-a-strong-password-here
POSTGRES_DB=css_prep_ai

# JWT
JWT_SECRET=choose-a-long-random-string-minimum-32-chars

# App
APP_ENV=development
LOG_LEVEL=INFO

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=choose-a-strong-password
