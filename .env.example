OPENAI_API_KEY=your_openai_api_key_here
CLAUDE_API_KEY=your_claude_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

ALLOWED_ORIGINS=http://localhost:5173,https://your-production-domain.com
RATE_LIMIT=30/minute
MAX_HISTORY_MESSAGES=8
ENABLE_RESPONSE_CACHE=true
RESPONSE_CACHE_TTL_SECONDS=120
RESPONSE_CACHE_MAX_ENTRIES=256

DATABASE_URL=sqlite+aiosqlite:///./css_prep_ai.db
# For PostgreSQL use: DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/css_prep_ai
JWT_SECRET=replace-this-with-a-long-random-string-in-production
MLFLOW_TRACKING_URI=http://localhost:5001
MLFLOW_EXPERIMENT_NAME=css-prep-ai-llm

VITE_API_BASE_URL=http://localhost:8000
